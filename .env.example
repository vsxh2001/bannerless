# --- Database (local SQLite file path; for Turso/libSQL swap the driver) ---
DATABASE_URL=./data/app.db

# --- Auth.js (NextAuth) ---
# Generate with: npx auth secret   (or: openssl rand -base64 32)
AUTH_SECRET=
# Public base URL of the app (used for auth callbacks + Stripe redirects)
AUTH_URL=http://localhost:3000
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Email of the first admin, seeded by `npm run db:seed`
ADMIN_EMAIL=vsxh2001@gmail.com

# --- Resend (magic-link emails) ---
# If unset in development, magic-link URLs are printed to the server console.
AUTH_RESEND_KEY=
EMAIL_FROM=Bannerless <onboarding@resend.dev>

# --- Stripe (monthly 50 ILS dues) ---
STRIPE_SECRET_KEY=
# From `stripe listen` or the Stripe dashboard webhook config
STRIPE_WEBHOOK_SECRET=

# --- Meta WhatsApp Cloud API ---
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
# Arbitrary string you choose; must match the value set in the Meta webhook config
WHATSAPP_VERIFY_TOKEN=
# Meta App Secret — when set, inbound webhooks must carry a valid
# X-Hub-Signature-256 (leave empty in local dev to skip signature checks)
WHATSAPP_APP_SECRET=
