# Dependencies are reinstalled cleanly via `npm ci` in the builder stage.
# (In this repo node_modules may also be a symlink pointing outside the build
# context — excluding it avoids a broken-symlink copy.)
node_modules
**/node_modules

# Build output (regenerated by `next build` in the builder stage).
.next
out
build

# VCS + worktree metadata.
.git
.gitignore
.claude

# Local SQLite database / volume data — never bake into the image.
data

# Secrets and local env files. .env.example is fine but not needed at build.
.env
.env.*
!.env.example

# Logs.
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Editor / OS cruft.
.DS_Store
*.pem
*.tsbuildinfo

# Docs and CI not needed in the image (optional).
*.md
.github

# Test + tooling configs not needed at runtime.
coverage
vitest.config.ts
eslint.config.mjs
